function Send-Webhook {
    param(
        [array]$CleanMods,
        [array]$UnknownMods,
        [array]$CheatMods
    )
    
    $colorBlue = 3447003
    
    $embed = @{
        title = "Mod Scan Report"
        color = $colorBlue
        fields = @()
        footer = @{
            text = "Scan completed at $(Get-Date -Format 'dd.MM.yyyy HH:mm:ss')"
        }
    }
    
    $summary = "Verified: $($CleanMods.Count)`n"
    $summary += "Unknown: $($UnknownMods.Count)`n"
    $summary += "Cheats: $($CheatMods.Count)"
    
    $embed.fields += @{
        name = "SUMMARY"
        value = $summary
        inline = $false
    }
    
    if ($CheatMods.Count -gt 0) {
        $cheatText = ""
        foreach ($mod in $CheatMods) {
            $modName = $null
            if ($mod.FileName) { $modName = $mod.FileName }
            elseif ($mod.ModName) { $modName = $mod.ModName }
            elseif ($mod.Name) { $modName = $mod.Name }
            else { $modName = "Unknown Mod" }
            
            $cheatText += "$modName`n"
            
            if ($mod.Patterns -and $mod.Patterns.Count -gt 0) {
                $cheatText += "Patterns: $($mod.Patterns -join ', ')`n"
            }
            if ($mod.Strings -and $mod.Strings.Count -gt 0) {
                $cheatText += "Strings: $($mod.Strings -join ', ')`n"
            }
            if ($mod.Hidden) {
                $cheatText += "Hidden`n"
            }
            $cheatText += "`n"
        }
        $embed.fields += @{
            name = "CHEAT MODS"
            value = $cheatText
            inline = $false
        }
    } else {
        $embed.fields += @{
            name = "CHEAT MODS"
            value = "No cheat mods found"
            inline = $false
        }
    }
    
    if ($UnknownMods.Count -gt 0) {
        $unknownText = ""
        foreach ($mod in $UnknownMods) {
            $modName = if ($mod.ModName) { $mod.ModName } else { $mod.FileName }
            $unknownText += "$modName`n"
            if ($mod.Hidden) {
                $unknownText += "Hidden`n"
            }
            $unknownText += "`n"
        }
        $embed.fields += @{
            name = "UNKNOWN MODS"
            value = $unknownText
            inline = $false
        }
    } else {
        $embed.fields += @{
            name = "UNKNOWN MODS"
            value = "No unknown mods found"
            inline = $false
        }
    }
    
    if ($CleanMods.Count -gt 0) {
        $cleanText = ""
        foreach ($mod in $CleanMods) {
            $cleanText += "$($mod.ModName)`n"
        }
        $embed.fields += @{
            name = "VERIFIED MODS"
            value = $cleanText
            inline = $false
        }
    } else {
        $embed.fields += @{
            name = "VERIFIED MODS"
            value = "No verified mods found"
            inline = $false
        }
    }
    
    $body = @{
        embeds = @($embed)
    } | ConvertTo-Json -Depth 10

    try {
        Invoke-RestMethod -Uri $webhookUrl -Method Post -Body $body -ContentType "application/json" -ErrorAction Stop
    } catch {
    }
}

