    Write-Host ("  " + ("ŌöĆ" * 70)) -ForegroundColor DarkYellow
    Write-Host "  Ōöé " -ForegroundColor DarkYellow -NoNewline
    Write-Host " OBFUSCATED " -ForegroundColor Black -BackgroundColor DarkYellow -NoNewline
    Write-Host "  " -NoNewline
    Write-Host $Mod.FileName -ForegroundColor Yellow
    Write-Host ("  Ōöé " + ("ŌöĆ" * 66)) -ForegroundColor DarkYellow

    foreach ($flag in $Mod.Flags) {
        if ($flag -match "^(.+?) ŌĆö (.+)$") {
            $flagTitle = $matches[1]
            $flagDesc  = $matches[2]
        } else {
            $flagTitle = $flag
            $flagDesc  = ""
        }

        Write-Host "  Ōöé" -ForegroundColor DarkYellow
        Write-Host "  Ōöé  " -ForegroundColor DarkYellow -NoNewline
        Write-Host "ŌÜæ " -ForegroundColor Yellow -NoNewline
        Write-Host $flagTitle -ForegroundColor White

        if ($flagDesc -ne "") {
            Write-Host "  Ōöé    " -ForegroundColor DarkYellow -NoNewline
            Write-Host $flagDesc -ForegroundColor Gray
        }
    }

    Write-Host "  Ōöé" -ForegroundColor DarkYellow
    Write-Host ("  " + ("ŌöĆ" * 70)) -ForegroundColor DarkYellow
    Write-Host ""
}

