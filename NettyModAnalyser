                    if ($hasAdvancedDecodeContext) {
                        for ($bi = 0; $bi -lt ($bytes.Length - 1); $bi++) {
                            if ($bytes[$bi] -eq 0xBC -and $bytes[$bi + 1] -eq 0x08) {
                                $hasByteNewArray = $true
                            }
                            if ($bytes[$bi] -eq 0xBC -and $bytes[$bi + 1] -eq 0x05) {
                                $hasCharNewArray = $true
                            }
                            if ($hasByteNewArray -and $hasCharNewArray) {
                                break
                            }
