    param([byte[]]$Bytes)

    $keys = [System.Collections.Generic.HashSet[int]]::new()
    foreach ($k in @(0, 1, 2, 3, 7, 13, 16, 23, 31, 32, 42, 55, 64, 69, 85, 90, 96, 100, 106, 127, 128, 170, 197, 255)) {
        [void]$keys.Add([int]$k)
    }
    if (-not $Bytes -or $Bytes.Length -eq 0) { return @($keys) }

    $plainChars = [System.Collections.Generic.HashSet[byte]]::new()
    foreach ($s in $script:cheatStrings) {
        if ([string]::IsNullOrEmpty($s)) { continue }
        $chars = $s.ToCharArray()
        foreach ($c in @($chars[0], $(if ($chars.Length -gt 1) { $chars[1] } else { $null }))) {
            if ($null -ne $c -and [int][char]$c -le 255) {
                [void]$plainChars.Add([byte][char]$c)
            }
        }
    }
    foreach ($c in @([byte][char]'A',[byte][char]'a',[byte][char]'d',[byte][char]'D',[byte][char]'h',[byte][char]'_',[byte][char]'.',[byte][char]' ')) {
        [void]$plainChars.Add($c)
    }

    $maxProbe = [Math]::Min(6, $Bytes.Length)
    foreach ($plain in $plainChars) {
        for ($i = 0; $i -lt $maxProbe; $i++) {
            $reverse = (($Bytes.Length - 1 - $i) -band 255)
            [void]$keys.Add((($Bytes[$i] -bxor $plain) -band 255))
            [void]$keys.Add((($Bytes[$i] -bxor $plain -bxor ($i -band 255)) -band 255))
            [void]$keys.Add((($Bytes[$i] -bxor $plain -bxor $reverse) -band 255))
            [void]$keys.Add((($Bytes[$i] - $plain - $i) -band 255))
            [void]$keys.Add((($plain - $Bytes[$i] - $i) -band 255))
        }
    }

    return @($keys)
}

function Get-ObfuscatedByteArrayStrings {
    param([byte[]]$Bytes)

    $decoded = [System.Collections.Generic.HashSet[string]]::new([System.StringComparer]::Ordinal)

    function Add-DecodedString {
        param([byte[]]$PlainBytes)
        try {
            $s = [System.Text.Encoding]::UTF8.GetString($PlainBytes)
            if ($s.Length -ge 3 -and $s.Length -le 220 -and $s -match '^[\u0009\u000A\u000D\u0020-\u007E]+$') {
                [void]$decoded.Add($s)
            }
        } catch { }
    }

    function Decode-XorVariants {
        param([byte[]]$Encoded)

        $len = $Encoded.Length
        foreach ($key in (Get-CheatCandidateKeys -Bytes $Encoded)) {
            $plainIndex = New-Object byte[] $len
            $plainPlain = New-Object byte[] $len
            $plainReverseIndex = New-Object byte[] $len
            $plainAddIndex = New-Object byte[] $len

            for ($j = 0; $j -lt $len; $j++) {
                $plainIndex[$j] = [byte](($Encoded[$j] -bxor $key -bxor ($j -band 0xFF)) -band 0xFF)
                $plainPlain[$j] = [byte](($Encoded[$j] -bxor $key) -band 0xFF)
                $plainReverseIndex[$j] = [byte](($Encoded[$j] -bxor $key -bxor (($len - 1 - $j) -band 0xFF)) -band 0xFF)
                $plainAddIndex[$j] = [byte]((($Encoded[$j] - $key - $j) -band 0xFF))
            }

            Add-DecodedString -PlainBytes $plainIndex
            Add-DecodedString -PlainBytes $plainPlain
            Add-DecodedString -PlainBytes $plainReverseIndex
            Add-DecodedString -PlainBytes $plainAddIndex
        }
    }

    for ($i = 0; $i -lt ($Bytes.Length - 2); $i++) {
        # Java bytecode: newarray byte = BC 08. Length is usually pushed immediately before it.
        if ($Bytes[$i] -ne 0xBC -or $Bytes[$i + 1] -ne 0x08) { continue }

        $len = Get-BytecodeIntConstantBefore -Bytes $Bytes -Position $i -LookBehind 4
        if ($null -eq $len -or $len -lt 3 -or $len -gt 220) { continue }

        $encoded = New-Object byte[] $len
        $stores = 0
        $scanEnd = [Math]::Min($Bytes.Length - 1, $i + 2 + ($len * 40) + 240)

        for ($p = $i + 2; $p -le $scanEnd -and $stores -lt $len; $p++) {
            # bastore
            if ($Bytes[$p] -ne 0x54) { continue }

            $value = Get-BytecodeIntConstantBefore -Bytes $Bytes -Position $p -LookBehind 18
            if ($null -eq $value) { continue }

            $encoded[$stores] = [byte]($value -band 0xFF)
            $stores++
        }

        if ($stores -ne $len) { continue }

        Decode-XorVariants -Encoded $encoded
    }

    # Java bytecode: newarray char = BC 05. Try static char-array strings.
    for ($i = 0; $i -lt ($Bytes.Length - 2); $i++) {
        if ($Bytes[$i] -ne 0xBC -or $Bytes[$i + 1] -ne 0x05) { continue }

        $len = Get-BytecodeIntConstantBefore -Bytes $Bytes -Position $i -LookBehind 4
        if ($null -eq $len -or $len -lt 3 -or $len -gt 220) { continue }

        $chars = New-Object int[] $len
        $stores = 0
        $scanEnd = [Math]::Min($Bytes.Length - 1, $i + 2 + ($len * 40) + 240)

        for ($p = $i + 2; $p -le $scanEnd -and $stores -lt $len; $p++) {
            # castore
            if ($Bytes[$p] -ne 0x55) { continue }

            $value = Get-BytecodeIntConstantBefore -Bytes $Bytes -Position $p -LookBehind 18
            if ($null -eq $value) { continue }

            $chars[$stores] = ($value -band 0xFFFF)
            $stores++
        }

        if ($stores -ne $len) { continue }

        try {
            $sb = New-Object System.Text.StringBuilder
            foreach ($c in $chars) { [void]$sb.Append([char]$c) }
            $s = $sb.ToString()
            if ($s.Length -ge 3 -and $s.Length -le 220 -and $s -match '^[\u0009\u000A\u000D\u0020-\u007E]+$') {
                [void]$decoded.Add($s)
            }
        } catch { }
    }

    # Pull Base64-looking constants from the class bytes and decode them.
    try {
        $ascii = [System.Text.Encoding]::ASCII.GetString($Bytes)
        foreach ($m in [regex]::Matches($ascii, '(?<![A-Za-z0-9+/=])[A-Za-z0-9+/]{12,}={0,2}(?![A-Za-z0-9+/=])')) {
            $candidate = $m.Value
            if (($candidate.Length % 4) -ne 0) { continue }
            try {
                $plain = [Convert]::FromBase64String($candidate)
                Add-DecodedString -PlainBytes $plain
            } catch { }
        }
    } catch { }

    return $decoded
}

