function Get-BytecodeIntConstantBefore {
    param(
        [byte[]]$Bytes,
        [int]$Position,
        [int]$LookBehind = 24
    )

    $start = [Math]::Max(0, $Position - $LookBehind)
    for ($i = $Position - 1; $i -ge $start; $i--) {
        $op = $Bytes[$i]
        if ($op -eq 0x10 -and ($i + 1) -lt $Position) {
            $v = [int]$Bytes[$i + 1]
            if ($v -ge 128) { $v -= 256 }
            return $v
        }
        if ($op -eq 0x11 -and ($i + 2) -lt $Position) {
            return [int16](($Bytes[$i + 1] -shl 8) -bor $Bytes[$i + 2])
        }
        if ($op -ge 0x03 -and $op -le 0x08) {
            return ($op - 0x03)
        }
        if ($op -eq 0x02) {
            return -1
        }
    }

    return $null
}

